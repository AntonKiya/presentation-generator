{
  "id": "cover",
  "intent": "Обложка, раздел или крупный вводный тезис",
  "layout_container_tree": {
    "type": "stack",
    "gap": 16,
    "align": "center",
    "justify": "center",
    "children": [
      {
        "type": "stack",
        "slot": "title",
        "accepts": ["title"],
        "required": true,
        "children": []
      },
      {
        "type": "stack",
        "slot": "body",
        "accepts": ["subtitle", "text"],
        "required": false,
        "children": []
      }
    ]
  },
  "limits": {
    "title_max_lines": 3,
    "subtitle_max_lines": 3,
    "text_max_lines": 4
  },
  "fallbacks": {}
}
